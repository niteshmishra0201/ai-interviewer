{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "module": "CommonJS",
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "declaration": true,
    "esModuleInterop": true,
    "resolveJsonModule": true

  }
}